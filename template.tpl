___SANDBOXED_JS_FOR_WEB_TEMPLATE___

const copyFromWindow = require('copyFromWindow');
const log = require('logToConsole');

const eventName = data.eventName;

if (!eventName) {
  log('Umami Track Event: eventName is required');
  data.gtmOnFailure();
  return;
}

const umami = copyFromWindow('umami');

if (!umami || !umami.track) {
  log('Umami Track Event: umami.track not available');
  data.gtmOnFailure();
  return;
}

const properties = {};
var hasProperties = false;

if (data.properties) {
  data.properties.forEach(function(row) {
    if (row.key) {
      properties[row.key] = row.value;
      hasProperties = true;
    }
  });
}

if (hasProperties) {
  umami.track(eventName, properties);
  log('Umami event sent:', eventName, properties);
} else {
  umami.track(eventName);
  log('Umami event sent:', eventName);
}

data.gtmOnSuccess();



___TESTS___

scenarios:
- name: Event with properties
  code: |-
    const mockData = {
      eventName: 'accordion_open',
      properties: [
        { key: 'question', value: 'This is the title' }
      ]
    };

    mock('copyFromWindow', function(key) {
      if (key === 'umami') {
        return {
          track: function(name, props) {
            assertThat(name).isEqualTo('accordion_open');
            assertThat(props.question).isEqualTo('This is the title');
          }
        };
      }
    });

    runCode(mockData);
    assertApi('gtmOnSuccess').wasCalled();
